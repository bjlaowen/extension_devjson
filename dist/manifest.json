{
  "manifest_version": 3,
  "name": "DevJSON",
  "version": "1.0.0",
  "description": "JSON 格式化、路径提取、Diff，以及生成 Go / Proto / TypeScript / Java / C# / Python 数据结构，开发者必备转换工具",
  "action": {
    "default_title": "DevJSON",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}